# -----------------------------------------------------------------------------
# Runtime path/config template (Draft)
# Copy to .env and adjust values for target server.
# -----------------------------------------------------------------------------

# Base project root (optional; defaults to repo root in config.py)
PROJECT_ROOT=

# Core I/O paths
DATA_PATH=
WORK_DIR=
RESULTS_DIR=
MODELS_DIR=

# Dataset/runtime selection
DATASET=human_lung
REFERENCE_ID=296C
BULK_ID=302C

# Pipeline behavior
MODEL=all
STAGES=prepare,run,eval
TRAIN_STEPS=5000
SCP_DATASET_NAME=human_lung_RNA
STANDARD_REBUILD_MODE=if_missing
PSEUDOBULK_ACTIVE_METHOD=uniform

# Conda/runtime switches
CONDA_EXE=
CONDA_SH=
CONDA_BAT=

# Environment names
ORCH_ENV=dzwdecode
SCADEN_ENV=scaden_env
SCP_ENV=scp_env
TAPE_ENV=tape_env
MUSIC_ENV=music_env

# Optional explicit model roots
MODEL_SCADEN_DIR=
MODEL_SCP_DECONV_DIR=
MODEL_TAPE_DIR=
MODEL_MUSIC_DIR=

# Optional logging/debug
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
